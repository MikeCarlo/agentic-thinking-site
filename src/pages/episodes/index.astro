---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveSearch from '../../components/ArchiveSearch.tsx';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const episodes = (await getCollection('episodes'))
  .sort((a, b) => b.data.episodeNumber - a.data.episodeNumber)
  .map((ep) => ({
    slug: ep.id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, ''),
    title: ep.data.title,
    episodeNumber: ep.data.episodeNumber,
    blurb: ep.data.blurb,
    tags: ep.data.tags,
    duration: ep.data.duration,
    guest: ep.data.guest,
  }));
---

<BaseLayout title="Episodes — Agentic Thinking">
  <div style="margin-bottom: 22px;">
    <div class="kicker">$ ls -la episodes/</div>
    <h1 class="h1">Episode index</h1>
    <p style="color: var(--fg-dim); margin-top: 10px; max-width: 60ch;">
      Every episode, searchable. Filter by topic. Click to watch.
    </p>
  </div>

  <ArchiveSearch client:load episodes={episodes} base={base} />
</BaseLayout>
