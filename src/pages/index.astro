---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => ({
    ...post,
    slug: post.id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, ''),
  }));
---

<BaseLayout title="Agentic Thinking" fullWidth={true}>
  <section class="mb-12 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-neutral-900">
      Agentic Thinking
    </h1>
    <p class="mt-4 text-lg text-neutral-600">
      Thoughts on AI agents, autonomous systems, and the future of agentic workflows.
    </p>
  </section>

  <section class="max-w-4xl mx-auto">
    <h2 class="text-xl font-semibold mb-6">Recent Posts</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <article class="rounded-xl border border-neutral-200 p-5 transition hover:-translate-y-1 hover:shadow-lg">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </p>
          <h3 class="mt-2 text-lg font-semibold">
            <a class="text-indigo-600 hover:text-indigo-700" href={`${base}/${post.slug}/`}>
              {post.data.title}
            </a>
          </h3>
          {post.data.excerpt && (
            <p class="mt-2 text-sm text-neutral-600 line-clamp-3">{post.data.excerpt}</p>
          )}
          {post.data.tags?.length ? (
            <div class="mt-4 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">
                  {tag}
                </span>
              ))}
            </div>
          ) : null}
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-neutral-500">No posts yet. Check back soon!</p>
    )}
  </section>
</BaseLayout>
