---
import BaseLayout from '../layouts/BaseLayout.astro';
import Win from '../components/Win.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="404 — Agentic Thinking">
  <Win path="error.log">
    <div style="text-align: center; padding: 40px 20px;">
      <div style="font-family: var(--font-mono); font-size: 48px; font-weight: 600; color: var(--accent);">404</div>
      <h1 style="font-family: var(--font-mono); font-size: 18px; margin-top: 12px; color: var(--fg);">page not found</h1>
      <p style="color: var(--fg-dim); margin-top: 8px; font-size: 13px;">
        > err: the requested route does not exist in the episode index.
      </p>
      <a href={`${base}/`} class="btn btn--primary" style="margin-top: 24px;">
        cd ~/home
      </a>
    </div>
  </Win>
</BaseLayout>
