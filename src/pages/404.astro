---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Page Not Found | Agentic Thinking" description="The page you are looking for could not be found.">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-6xl font-bold text-indigo-600">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-neutral-900">Page Not Found</h1>
    <p class="mt-2 text-neutral-600">Sorry, we couldn't find the page you're looking for.</p>
    <a
      href={`${base}/`}
      class="mt-8 rounded-full bg-indigo-600 px-6 py-2 text-sm font-semibold text-white hover:bg-indigo-700 transition-colors"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>
