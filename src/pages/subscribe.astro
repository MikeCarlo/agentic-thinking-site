---
import BaseLayout from '../layouts/BaseLayout.astro';
import Win from '../components/Win.astro';
import { addCampaignParams } from '../utils/campaign';
---

<BaseLayout title="Listen — Agentic Thinking">
  <div style="margin-bottom: 22px;">
    <div class="kicker">$ where --to listen</div>
    <h1 class="h1">Where to Listen</h1>
  </div>

  <Win path="listen.platforms">
    <h2 class="h2">Platforms</h2>
    <ul class="ls-rows" style="padding: 0;">
      <li>▸ <b>YouTube</b> — <a href={addCampaignParams("https://www.youtube.com/@PowerBITips")} target="_blank" rel="noopener" style="color: var(--accent-2);">@PowerBITips</a></li>
      <li style="color: var(--fg-mute);">▸ more platforms coming soon</li>
    </ul>
  </Win>
</BaseLayout>
