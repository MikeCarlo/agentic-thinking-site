---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;

function isActive(route: string) {
  if (route === '/') return path === base + '/' || path === base;
  return path.startsWith(base + route);
}

const isHome = isActive('/') && !path.includes('/episodes') && !path.includes('/about') && !path.includes('/subscribe');
---

<nav class="topnav">
  <div class="topnav__brand">
    <a href={`${base}/`}><b>AGENTIC_THINKING</b></a>
    <span class="sep">›</span>
    <span class="topnav__path">podcast/intelligence/agents</span>
  </div>
  <div class="topnav__nav">
    <a href={`${base}/`} class={isHome ? 'active' : ''}>home</a>
    <a href={`${base}/episodes/`} class={isActive('/episodes') ? 'active' : ''}>episodes</a>
    <a href={`${base}/about/`} class={isActive('/about') ? 'active' : ''}>hosts</a>
    <a href={`${base}/subscribe/`} class={isActive('/subscribe') ? 'active' : ''}>subscribe</a>
  </div>
</nav>
