---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Agentic Thinking',
  description = 'Thoughts on AI agents, autonomous systems, and the future of agentic workflows.',
  fullWidth = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="bg-white text-neutral-900 min-h-screen flex flex-col">
    <Header />
    <main class={`mx-auto w-full px-6 py-10 flex-grow ${fullWidth ? '' : 'max-w-4xl'}`}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
