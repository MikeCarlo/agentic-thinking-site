---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, author, tags, excerpt } = post.data;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | Agentic Thinking`} description={excerpt}>
  <article class="prose mx-auto">
    <header class="not-prose mb-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-neutral-500">
        {formattedDate}
      </p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
        {title}
      </h1>
      {excerpt && (
        <p class="mt-4 text-lg text-neutral-600">{excerpt}</p>
      )}
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-neutral-500">
        <span>By {author}</span>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`${base}/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`}
                class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600 hover:bg-neutral-200 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <slot />
  </article>
</BaseLayout>
